{
	"name": "jlang-support",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:schema": "psql $DATABASE_URL -f db/schema.sql",
		"import:kanjidic": "npx tsx scripts/import-kanjidic.ts",
		"import:kradfile": "npx tsx scripts/import-kradfile.ts",
		"import:kanjivg": "npx tsx scripts/import-kanjivg.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.2",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/pg": "^8.20.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"fast-xml-parser": "^5.5.8",
		"pg": "^8.20.0"
	}
}
